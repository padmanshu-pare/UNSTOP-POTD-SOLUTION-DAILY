/*
Problem: Diamond Boxes (Minimum maximum diamonds per trip)
Approach: Binary Search on Answer (Book Allocation Pattern)

Time Complexity: O(N * log(S))
    where S = sum of array elements
Space Complexity: O(1)
*/

#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

/*
    Checks if it is possible to transfer all diamonds
    within T trips such that no trip exceeds maxCapacity.
*/
bool canDistribute(const vector<int>& arr, int T, int maxCapacity) {
    int tripsRequired = 1;
    int currentLoad = 0;

    for (int diamonds : arr) {
        if (currentLoad + diamonds <= maxCapacity) {
            currentLoad += diamonds;
        } else {
            tripsRequired++;
            currentLoad = diamonds;

            if (tripsRequired > T)
                return false;
        }
    }
    return true;
}

/*
    Returns minimum number of boxes required per trip
    to transfer all diamonds in T trips.
*/
int minimumDiamondBoxes(const vector<int>& arr, int T) {

    int low = *max_element(arr.begin(), arr.end());   // Minimum possible
    int high = 0;                                    // Maximum possible

    for (int diamonds : arr)
        high += diamonds;

    int answer = high;

    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (canDistribute(arr, T, mid)) {
            answer = mid;
            high = mid - 1;  // Try smaller capacity
        } else {
            low = mid + 1;   // Increase capacity
        }
    }

    return answer;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int N, T;
    cin >> N;

    vector<int> arr(N);
    for (int i = 0; i < N; ++i) {
        cin >> arr[i];
    }

    cin >> T;

    cout << minimumDiamondBoxes(arr, T) << "\n";
    return 0;
}
